{
  "name": "computer-use-win-napi-axiomate",
  "version": "0.1.0",
  "description": "Windows native bindings for computer-use: registry-walk app enumeration, WindowFromPoint hit-test, MonitorFromWindow display mapping, token elevation probe",
  "main": "index.js",
  "types": "index.d.ts",
  "files": ["index.js", "index.d.ts", "*.node"],
  "scripts": {
    "build": "napi build --release --dts .napi-generated.d.ts",
    "build:debug": "napi build --dts .napi-generated.d.ts",
    "test": "vitest run --passWithNoTests"
  },
  "napi": {
    "name": "computer-use-win-napi-axiomate",
    "triples": {
      "additional": ["x86_64-pc-windows-msvc", "aarch64-pc-windows-msvc"]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "vitest": "^1.0.0"
  }
}
