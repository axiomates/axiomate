{
  "name": "axiomate",
  "version": "0.6.1",
  "description": "Terminal AI coding agent. Bring your own model — any OpenAI- or Anthropic-compatible API. Built-in file/shell/MCP tooling, macOS computer-use, ships as a single Bun-compiled executable.",
  "type": "module",
  "main": "./dist/cli.js",
  "scripts": {
    "build": "bun run build.ts",
    "build:dev": "bun run build.ts --features=DEV",
    "package:mac": "bun run package-mac.ts",
    "package:mac:dev": "bun run package-mac.ts --features=DEV",
    "package:win": "bun run package-win.ts",
    "package:win:dev": "bun run package-win.ts --features=DEV",
    "build:types": "tsc --noEmit",
    "start": "bun dist/cli.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "test:e2e": "vitest run --passWithNoTests --config vitest.e2e.config.ts",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "vitest run --coverage --config vitest.all.config.ts"
  },
  "dependencies": {
