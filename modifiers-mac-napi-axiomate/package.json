{
  "name": "modifiers-mac-napi-axiomate",
  "version": "0.1.0",
  "description": "macOS native keyboard modifier key state query via Rust NAPI",
  "main": "index.js",
  "types": "index.d.ts",
  "files": ["index.js", "index.d.ts", "*.node"],
  "scripts": {
    "build": "napi build --release --dts .napi-generated.d.ts",
    "build:debug": "napi build --dts .napi-generated.d.ts",
    "test": "vitest run"
  },
  "napi": {
    "name": "modifiers-mac-napi-axiomate",
    "triples": {
      "additional": ["aarch64-apple-darwin", "x86_64-apple-darwin"]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "vitest": "^1.0.0"
  }
}
