{
  "name": "audio-capture-axiomate",
  "version": "0.1.0",
  "description": "Cross-platform native audio recording and playback via Rust NAPI (cpal)",
  "main": "index.js",
  "types": "index.d.ts",
  "files": ["index.js", "index.d.ts", "*.node"],
  "scripts": {
    "build": "napi build --release --dts .napi-generated.d.ts",
    "build:debug": "napi build --dts .napi-generated.d.ts",
    "test": "vitest run"
  },
  "napi": {
    "name": "audio-capture-axiomate",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "vitest": "^1.0.0"
  }
}
